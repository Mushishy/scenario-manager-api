{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "type": { "type": "string", "enum": ["SHARED", "INDIVIDUAL"] },
        "usersAndTeams": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "user": { "type": "string" },
                    "team": { "type": "string" },
                    "mainUserId": { "type": "string" }
                },
                "required": ["user"],
                "additionalProperties": false
            }
        }
    },
    "required": ["type", "usersAndTeams"],
    "additionalProperties": false,
    "if": {
        "properties": { "type": { "const": "INDIVIDUAL" } }
    },
    "then": {
        "properties": {
            "usersAndTeams": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "user": { "type": "string" },
                        "team": { "type": "string" }
                    },
                    "required": ["user"],
                    "additionalProperties": false
                }
            }
        }
    },
    "else": {
        "properties": {
            "usersAndTeams": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "user": { "type": "string" },
                        "team": { "type": "string" },
                        "mainUserId": { "type": "string" }
                    },
                    "required": ["user", "mainUserId"],
                    "additionalProperties": false
                }
            }
        }
    }
}